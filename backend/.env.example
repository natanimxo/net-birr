# Copy this to .env and fill in real values. Never commit .env.

# Local dev: Neon free-tier Postgres. Production (Railway) uses a separate DATABASE_URL
# injected as a Railway env var, never stored in this repo.
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# New Telegram bot created just for login (BotFather) - separate from any existing bot.
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_BOT_USERNAME=replace_me_bot

# Random secret for signing app session JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=43200

# Free-tier enforcement (Phase 1 default; revisit once research comes back)
FREE_DAILY_TRANSACTION_CAP=5

# Comma-separated Telegram user IDs allowed to use Admin payment-approval endpoints.
ADMIN_TELEGRAM_IDS=000000000

# Manual payment verification (Ethio Matric-style). NEVER commit real values here -
# set these directly in Railway (production) / your local .env (dev, gitignored).
TELEBIRR_NUMBER=TODO_FILL_IN
TELEBIRR_NAME=TODO_FILL_IN
CBE_ACCOUNT=TODO_FILL_IN
AWASH_ACCOUNT=TODO_FILL_IN

PRICE_MONTHLY_BIRR=200
PRICE_YEARLY_BIRR=2000

ENVIRONMENT=development
